{
    "name": "Wifi Connection App",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/app",
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack",
                "redhat.java",
                "vscjava.vscode-maven",
                "vscjava.vscode-spring-boot-dashboard"
            ],
            "settings": {
                "java.configuration.runtimes": [
                    { "name": "JavaSE-21", "path": "/opt/java/openjdk", "default": true }
                ]
            }
        }
    },
    "remoteEnv": { "JAVA_HOME": "/opt/java/openjdk" }
}